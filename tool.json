{
  "$schema": "https://toolbag.lfen.dev/schemas/plugin/1.json",
  "id": "com.lfen.toolbag.hash-and-base64",
  "name": "Hash & Base64",
  "version": "0.1.0",
  "category": "实用",
  "tags": ["加密", "编码", "调试", "实用"],
  "description": "本地计算文本哈希、Base64 编解码、HMAC 签名与 JWT 解析。",
