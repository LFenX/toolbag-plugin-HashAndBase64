  "author": { "name": "LFen", "url": "https://github.com/LFenX" },
  "license": "MIT",
  "homepage": "https://github.com/LFenX/toolbag-plugin-HashAndBase64",
  "minAppVersion": "0.2.0",
  "riskLevel": "safe",
  "requiresElevation": false,
  "permissionRequirement": "普通权限",
  "dataAccess": "仅在内存中处理用户输入，不读写文件、不联网",
  "icon": "icon.svg",
  "runtime": {
    "kind": "sidecar",
    "binary": "bin/sidecar-windows-x64.exe",
    "args": [],
    "env": {},
    "startupTimeoutMs": 3000,
    "shutdownTimeoutMs": 1500
  },
  "commands": [
    { "id": "run", "label": "执行" }
  ],
  "ui": "ui.json"
}
