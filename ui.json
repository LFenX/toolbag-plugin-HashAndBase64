{
  "$schema": "https://toolbag.lfen.dev/schemas/ui/1.json",
  "layout": "split",
  "header": {
    "showVersion": true,
    "showRisk": true
  },
  "left": {
    "title": "输入",
    "description": "选择模式后填写对应字段，点击「执行」运行。",
    "fields": [
      {
        "key": "mode",
        "type": "tabs",
        "default": "hash",
        "options": [
          { "value": "hash", "label": "Hash" },
          { "value": "base64", "label": "Base64" },
          { "value": "hmac", "label": "HMAC-SHA256" },
          { "value": "jwt", "label": "JWT" }
        ]
      },

      {
        "key": "hash_algo",
        "type": "radioGroup",
        "label": "算法",
        "default": "sha256",
        "options": [
          { "value": "md5", "label": "MD5" },
          { "value": "sha1", "label": "SHA-1" },
          { "value": "sha256", "label": "SHA-256" },
          { "value": "sha512", "label": "SHA-512" }
        ],
        "visibleWhen": "mode==hash"
      },
      {
        "key": "hash_input",
        "type": "textarea",
        "label": "文本",
        "rows": 8,
        "monospace": true,
        "placeholder": "在这里粘贴或输入要计算哈希的文本…",
        "visibleWhen": "mode==hash"
      },

      {
        "key": "b64_op",
        "type": "radioGroup",
        "label": "操作",
        "default": "encode",
        "options": [
          { "value": "encode", "label": "编码（文本 → Base64）" },
          { "value": "decode", "label": "解码（Base64 → 文本）" }
        ],
        "visibleWhen": "mode==base64"
      },
      {
        "key": "b64_input",
        "type": "textarea",
        "label": "内容",
        "rows": 8,
        "monospace": true,
        "placeholder": "支持中文与 Emoji；解码时按 UTF-8 解释字节。",
        "visibleWhen": "mode==base64"
      },

      {
        "key": "hmac_secret",
        "type": "text",
        "label": "Secret",
        "placeholder": "用于签名的密钥（明文）",
        "visibleWhen": "mode==hmac"
      },
      {
        "key": "hmac_payload",
        "type": "textarea",
        "label": "Payload",
        "rows": 8,
        "monospace": true,
        "placeholder": "要签名的内容…",
        "visibleWhen": "mode==hmac"
      },

      {
        "key": "jwt_token",
        "type": "textarea",
        "label": "JWT Token",
        "rows": 8,
        "monospace": true,
        "placeholder": "粘贴形如 xxx.yyy.zzz 的 JWT…",
        "visibleWhen": "mode==jwt"
      }
    ],
    "actions": [
      { "id": "run", "label": "执行", "primary": true, "command": "run" },
      { "id": "copy", "label": "复制结果", "kind": "copy", "source": "$result" },
      { "id": "clear", "label": "清空", "kind": "reset" }
    ]
  },
  "right": {
    "kind": "result",
    "title": "结果",
    "renderers": [
      { "type": "status" },
      { "type": "keyValue", "source": "$result.summary" },
      { "type": "code", "source": "$result.data", "language": "json", "wrap": true }
    ]
  }
}
