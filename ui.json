{
  "$schema": "https://toolbag.lfen.dev/schemas/ui/1.json",
  "layout": "split",
  "header": {
    "showVersion": true,
    "showRisk": true
  },
  "left": {
    "title": "输入",
    "description": "常用 Hash、Base64、HMAC 与 JWT 小工具，所有计算都在本机完成。",
    "fields": [
      {
        "key": "mode",
        "type": "tabs",
        "default": "hash",
        "options": [
          { "value": "hash", "label": "Hash" },
          { "value": "base64_encode", "label": "Base64 编码" },
          { "value": "base64_decode", "label": "Base64 解码" },
          { "value": "hmac", "label": "HMAC" },
          { "value": "jwt", "label": "JWT" }
        ]
      },
      {
        "key": "hash_algo",
        "type": "radioGroup",
        "label": "算法",
        "default": "sha256",
        "options": [
          { "value": "md5", "label": "MD5" },
          { "value": "sha1", "label": "SHA-1" },
          { "value": "sha256", "label": "SHA-256" },
          { "value": "sha512", "label": "SHA-512" }
        ],
        "visibleWhen": "mode == null || mode == 'hash'"
      },
      {
        "key": "hash_input",
        "type": "textarea",
        "label": "原文",
        "rows": 10,
        "monospace": true,
        "placeholder": "粘贴要计算 Hash 的文本，例如：hello 世界",
        "required": true,
        "visibleWhen": "mode == null || mode == 'hash'"
      },
      {
        "key": "b64_plain",
        "type": "textarea",
        "label": "原文",
        "rows": 12,
        "monospace": true,
        "placeholder": "粘贴要编码成 Base64 的文本，支持中文和 Emoji",
        "required": true,
        "visibleWhen": "mode == 'base64_encode'"
      },
      {
        "key": "b64_encoded",
        "type": "textarea",
        "label": "Base64",
        "rows": 12,
        "monospace": true,
        "placeholder": "粘贴要解码的 Base64，标准 Base64 和 URL-safe Base64 都支持",
        "required": true,
        "visibleWhen": "mode == 'base64_decode'"
      },
      {
        "key": "hmac_secret",
        "type": "text",
        "label": "密钥",
        "placeholder": "例如：my-secret",
        "required": true,
        "visibleWhen": "mode == 'hmac'"
      },
      {
        "key": "hmac_payload",
        "type": "textarea",
        "label": "正文",
        "rows": 10,
        "monospace": true,
        "placeholder": "粘贴要签名的内容，例如：foo=bar&time=1234",
        "required": true,
        "visibleWhen": "mode == 'hmac'"
      },
      {
        "key": "jwt_token",
        "type": "textarea",
        "label": "JWT",
        "rows": 10,
        "monospace": true,
        "placeholder": "粘贴形如 header.payload.signature 的 JWT",
        "help": "只解析 header 和 payload，不做签名验证。",
        "required": true,
        "visibleWhen": "mode == 'jwt'"
      }
    ],
    "actions": [
      { "id": "run", "label": "执行", "primary": true, "command": "run" },
      { "id": "copy", "label": "复制核心结果", "kind": "copy", "source": "$result.data.result" },
      { "id": "clear", "label": "清空", "kind": "reset" }
    ]
  },
  "right": {
    "kind": "result",
    "title": "结果",
    "renderers": [
      { "type": "status" },
      { "type": "keyValue", "source": "$result.summary" },
      { "type": "code", "source": "$result.data.result", "language": "text", "wrap": true }
    ]
  }
}
